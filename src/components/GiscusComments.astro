---
// Giscus 评论系统
// 配置步骤：
// 1. 仓库安装 Giscus App: https://github.com/apps/giscus
// 2. 开启 Discussions (Settings → General → Features → Discussions)
// 3. 访问 https://giscus.app/zh-CN 获取 repo-id 和 category-id
// 4. 填入下方配置
const config = {
  repo: "Huaixuov0/myblog",
  repoId: "", // ← 填入你的 repo-id
  category: "Announcements",
  categoryId: "", // ← 填入你的 category-id
};
const enabled = config.repoId && config.categoryId;
---

{enabled ? (
  <div class="comments-section" id="comments">
    <h3>评论</h3>
    <div id="giscus-container" style="margin-top: 1rem;"></div>
    <script is:inline define:vars={{ config }}>
      (function () {
        const script = document.createElement("script");
        script.src = "https://giscus.app/client.js";
        script.setAttribute("data-repo", config.repo);
        script.setAttribute("data-repo-id", config.repoId);
        script.setAttribute("data-category", config.category);
        script.setAttribute("data-category-id", config.categoryId);
        script.setAttribute("data-mapping", "pathname");
        script.setAttribute("data-strict", "0");
        script.setAttribute("data-reactions-enabled", "1");
        script.setAttribute("data-emit-metadata", "0");
        script.setAttribute("data-input-position", "top");
        script.setAttribute("data-theme", document.documentElement.classList.contains("dark") ? "dark" : "light");
        script.setAttribute("data-lang", "zh-CN");
        script.crossOrigin = "anonymous";
        script.async = true;
        document.getElementById("giscus-container").appendChild(script);
      })();
    </script>
  </div>
) : null}
