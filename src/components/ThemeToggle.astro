<button class="theme-toggle" id="theme-toggle" aria-label="切换主题" title="切换暗色/亮色模式">
  <span class="light-icon">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
      <path d="M8 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-1 0v-1A.5.5 0 0 1 8 1zm0 10a3 3 0 1 1 0-6 3 3 0 0 1 0 6zm5.657-5.657a.5.5 0 0 1 0 .707l-.707.707a.5.5 0 0 1-.707-.707l.707-.707a.5.5 0 0 1 .707 0zM2.343 9.657a.5.5 0 0 1 .707 0l.707.707a.5.5 0 1 1-.707.707l-.707-.707a.5.5 0 0 1 0-.707zM6.343 1.343a.5.5 0 0 1 .707.707l-.707.707a.5.5 0 0 1-.707-.707l.707-.707zM13.657 7.657a.5.5 0 0 1-.707.707l-.707-.707a.5.5 0 0 1 .707-.707l.707.707zM1 8a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1A.5.5 0 0 1 1 8zm10 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1A.5.5 0 0 1 11 8zM5.05 3.636a.5.5 0 0 1 .707.707l-.707.707a.5.5 0 0 1-.707-.707l.707-.707zm7.07 7.07a.5.5 0 0 1-.707.707l-.707-.707a.5.5 0 0 1 .707-.707l.707.707z"/>
    </svg>
  </span>
  <span class="dark-icon" style="display:none;">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
      <path d="M6 .278a.768.768 0 0 1 .08.858 7.208 7.208 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277.527 0 1.04-.055 1.533-.16a.787.787 0 0 1 .81.316.733.733 0 0 1-.031.893A8.349 8.349 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06A.752.752 0 0 1 6 .278z"/>
    </svg>
  </span>
</button>

<script>
  const btn = document.getElementById("theme-toggle")!;
  const lightIcon = btn.querySelector(".light-icon") as HTMLElement;
  const darkIcon = btn.querySelector(".dark-icon") as HTMLElement;
  const html = document.documentElement;

  function updateIcons() {
    const isDark = html.classList.contains("dark");
    lightIcon.style.display = isDark ? "none" : "";
    darkIcon.style.display = isDark ? "" : "none";
  }

  updateIcons();

  btn.addEventListener("click", () => {
    html.classList.toggle("dark");
    const theme = html.classList.contains("dark") ? "dark" : "light";
    localStorage.setItem("theme", theme);
    updateIcons();
  });
</script>
